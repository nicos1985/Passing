# .env.example
# Email Configuration for Threat Intelligence

# Email Backend: "smtp" (default) or "brevo"
THREAT_INTEL_EMAIL_BACKEND=smtp

# SMTP Configuration (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@anima.bot
EMAIL_HOST_PASSWORD=bqrgbxmleytmtkyf
DEFAULT_FROM_EMAIL=noreply@anima.bot
DEFAULT_FROM_NAME=Threat Intel System

# Brevo (SendinBlue) - Optional
# Get API key from: https://www.brevo.com/settings/api/
BREVO_API_KEY=xkeysib-1234567890abcdef1234567890abcdef

# Report Settings
THREAT_INTEL_REPORT_INCLUDE_PDF=true
THREAT_INTEL_REPORT_MAX_ITEMS=50

# Email Logging (optional)
LOG_EMAILS=true
EMAIL_LOG_PATH=/var/log/django/emails.log
